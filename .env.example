# Docker Compose environment variables
# Copy this to .env and fill in your values

# PostgreSQL
POSTGRES_PASSWORD=your_strong_password_here

# JWT
JWT_SECRET=generate_with_openssl_rand_hex_64
JWT_EXPIRY=7d

# App mode
NODE_ENV=production

# Frontend public variables (used at Docker build time)
NEXT_PUBLIC_API_URL=https://api.caretakerapp.com/api
NEXT_PUBLIC_APP_DOMAIN=caretakerapp.com
NEXT_PUBLIC_APP_NAME=Caretaker
CORS_ORIGIN=https://caretakerapp.com,https://www.caretakerapp.com
APP_DOMAIN=caretakerapp.com

# S3-compatible storage
STORAGE_ENDPOINT=https://s3.example.com
STORAGE_REGION=garage
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET_NAME=caretaker
STORAGE_PUBLIC_URL=https://web.example.com
