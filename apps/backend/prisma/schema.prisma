generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Flat {
  id              String                   @id @default(cuid())
  name            String
  slug            String                   @unique
  subdomain       String?                  @unique
  address         String?
  logoUrl         String?
  themeColor      String?                  @default("#3B82F6")
  contactPerson   String?
  contactPhone    String?
  status          FlatStatus               @default(ACTIVE)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  imageUrl        String?
  foodOrders      FoodOrder[]
  gatePasses      GatePass[]
  groceryItems    GroceryItem[]
  groceryOrders   GroceryOrder[]
  hotels          Hotel[]
  marketListings  MarketListing[]
  marketMessages  MarketMessage[]
  serviceBookings ServiceBooking[]
  services        Service[]
  timeSlots       TimeSlot[]
  unavailableReqs UnavailableItemRequest[]
  users           User[]

  @@map("flats")
}

model User {
  id                 String                   @id @default(cuid())
  flatId             String?
  name               String
  email              String                   @unique
  phone              String?
  passwordHash       String
  role               Role
  flatNumber         String?
  isActive           Boolean                  @default(true)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  foodOrders         FoodOrder[]
  approvedGatePasses GatePass[]               @relation("ApprovedBy")
  gatePassRequests   GatePass[]               @relation("ResidentGatePasses")
  groceryOrders      GroceryOrder[]
  marketListings     MarketListing[]          @relation("MarketSeller")
  marketMessages     MarketMessage[]
  serviceBookings    ServiceBooking[]
  unavailableReqs    UnavailableItemRequest[]
  flat               Flat?                    @relation(fields: [flatId], references: [id], onDelete: Cascade)

  @@map("users")
}

model GroceryItem {
  id              String                   @id @default(cuid())
  flatId          String
  name            String
  description     String?
  price           Decimal                  @db.Decimal(10, 2)
  imageUrl        String?
  category        String?
  stockStatus     String                   @default("IN_STOCK")
  isActive        Boolean                  @default(true)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  flat            Flat                     @relation(fields: [flatId], references: [id], onDelete: Cascade)
  orderItems      GroceryOrderItem[]
  unavailableReqs UnavailableItemRequest[]

  @@map("grocery_items")
}

model GroceryOrder {
  id          String             @id @default(cuid())
  flatId      String
  residentId  String
  status      OrderStatus        @default(PENDING)
  totalAmount Decimal            @db.Decimal(10, 2)
  notes       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  items       GroceryOrderItem[]
  flat        Flat               @relation(fields: [flatId], references: [id], onDelete: Cascade)
  resident    User               @relation(fields: [residentId], references: [id])

  @@map("grocery_orders")
}

model GroceryOrderItem {
  id               String       @id @default(cuid())
  orderId          String
  groceryItemId    String
  itemNameSnapshot String
  priceSnapshot    Decimal      @db.Decimal(10, 2)
  quantity         Int
  subtotal         Decimal      @db.Decimal(10, 2)
  groceryItem      GroceryItem  @relation(fields: [groceryItemId], references: [id])
  order            GroceryOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("grocery_order_items")
}

model UnavailableItemRequest {
  id            String        @id @default(cuid())
  flatId        String
  residentId    String
  groceryItemId String?
  itemName      String
  quantity      String?
  notes         String?
  status        RequestStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  flat          Flat          @relation(fields: [flatId], references: [id], onDelete: Cascade)
  groceryItem   GroceryItem?  @relation(fields: [groceryItemId], references: [id])
  resident      User          @relation(fields: [residentId], references: [id])

  @@map("unavailable_item_requests")
}

model Hotel {
  id          String      @id @default(cuid())
  flatId      String
  name        String
  description String?
  imageUrl    String?
  phone       String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  foodItems   FoodItem[]
  foodOrders  FoodOrder[]
  flat        Flat        @relation(fields: [flatId], references: [id], onDelete: Cascade)

  @@map("hotels")
}

model FoodItem {
  id          String          @id @default(cuid())
  flatId      String
  hotelId     String
  name        String
  description String?
  price       Decimal         @db.Decimal(10, 2)
  imageUrl    String?
  category    String?
  isAvailable Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  hotel       Hotel           @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  orderItems  FoodOrderItem[]

  @@map("food_items")
}

model FoodOrder {
  id          String          @id @default(cuid())
  flatId      String
  hotelId     String
  residentId  String
  status      OrderStatus     @default(PENDING)
  totalAmount Decimal         @db.Decimal(10, 2)
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  items       FoodOrderItem[]
  flat        Flat            @relation(fields: [flatId], references: [id], onDelete: Cascade)
  hotel       Hotel           @relation(fields: [hotelId], references: [id])
  resident    User            @relation(fields: [residentId], references: [id])

  @@map("food_orders")
}

model FoodOrderItem {
  id               String    @id @default(cuid())
  orderId          String
  foodItemId       String
  itemNameSnapshot String
  priceSnapshot    Decimal   @db.Decimal(10, 2)
  quantity         Int
  subtotal         Decimal   @db.Decimal(10, 2)
  foodItem         FoodItem  @relation(fields: [foodItemId], references: [id])
  order            FoodOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("food_order_items")
}

model Service {
  id          String           @id @default(cuid())
  flatId      String
  name        String
  description String?
  imageUrl    String?
  basePrice   Decimal?         @db.Decimal(10, 2)
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  bookings    ServiceBooking[]
  flat        Flat             @relation(fields: [flatId], references: [id], onDelete: Cascade)
  timeSlots   TimeSlot[]

  @@map("services")
}

model TimeSlot {
  id              String           @id @default(cuid())
  flatId          String
  serviceId       String
  date            String
  startTime       String
  endTime         String
  maxBookings     Int              @default(1)
  currentBookings Int              @default(0)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  bookings        ServiceBooking[]
  flat            Flat             @relation(fields: [flatId], references: [id], onDelete: Cascade)
  service         Service          @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@map("time_slots")
}

model ServiceBooking {
  id         String        @id @default(cuid())
  flatId     String
  serviceId  String
  timeSlotId String
  residentId String
  status     BookingStatus @default(PENDING)
  notes      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  flat       Flat          @relation(fields: [flatId], references: [id], onDelete: Cascade)
  resident   User          @relation(fields: [residentId], references: [id])
  service    Service       @relation(fields: [serviceId], references: [id])
  timeSlot   TimeSlot      @relation(fields: [timeSlotId], references: [id])

  @@map("service_bookings")
}

model GatePass {
  id                   String         @id @default(cuid())
  flatId               String
  residentId           String
  visitorName          String
  visitorPhone         String?
  purpose              String?
  expectedVisitDate    String
  expectedVisitTime    String?
  status               GatePassStatus @default(PENDING)
  approvedBySecurityId String?
  entryTime            DateTime?
  exitTime             DateTime?
  notes                String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  approvedBy           User?          @relation("ApprovedBy", fields: [approvedBySecurityId], references: [id])
  flat                 Flat           @relation(fields: [flatId], references: [id], onDelete: Cascade)
  resident             User           @relation("ResidentGatePasses", fields: [residentId], references: [id])

  @@map("gate_passes")
}

model MarketListing {
  id          String              @id @default(cuid())
  flatId      String
  sellerId    String
  title       String
  description String?
  price       Decimal             @db.Decimal(10, 2)
  imageUrl    String?
  category    String?
  condition   String?
  status      MarketListingStatus @default(AVAILABLE)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  flat        Flat                @relation(fields: [flatId], references: [id], onDelete: Cascade)
  seller      User                @relation("MarketSeller", fields: [sellerId], references: [id])
  messages    MarketMessage[]

  @@map("market_listings")
}

model MarketMessage {
  id        String        @id @default(cuid())
  flatId    String
  listingId String
  senderId  String
  message   String
  createdAt DateTime      @default(now())
  flat      Flat          @relation(fields: [flatId], references: [id], onDelete: Cascade)
  listing   MarketListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  sender    User          @relation(fields: [senderId], references: [id])

  @@map("market_messages")
}

model PlatformSetting {
  key       String   @id
  value     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("platform_settings")
}

enum Role {
  SUPER_ADMIN
  FLAT_ASSOCIATION
  SECURITY
  RESIDENT
}

enum FlatStatus {
  ACTIVE
  INACTIVE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  COMPLETED
  CANCELLED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum GatePassStatus {
  PENDING
  APPROVED
  REJECTED
  ENTERED
  EXITED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum MarketListingStatus {
  AVAILABLE
  RESERVED
  SOLD
  INACTIVE
}
