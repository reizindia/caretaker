NODE_ENV=development
PORT=3001

DATABASE_URL=postgresql://postgres:password@localhost:5432/caretaker_db

JWT_SECRET=your-super-secret-jwt-key-min-32-characters-here
JWT_EXPIRY=7d
APP_DOMAIN=caretakerapp.com
CORS_ORIGIN=https://caretakerapp.com,https://www.caretakerapp.com,https://api.caretakerapp.com

STORAGE_ENDPOINT=https://s3.example.com
STORAGE_ACCESS_KEY_ID=your-access-key
STORAGE_SECRET_ACCESS_KEY=your-secret-key
STORAGE_BUCKET_NAME=caretaker
STORAGE_PUBLIC_URL=https://web.example.com
STORAGE_REGION=garage
