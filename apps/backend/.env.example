NODE_ENV=development
PORT=3001

DATABASE_URL=postgresql://postgres:password@localhost:5432/caretaker_db

JWT_SECRET=your-super-secret-jwt-key-min-32-characters-here
JWT_EXPIRES_IN=7d

STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY_ID=your-access-key
STORAGE_SECRET_ACCESS_KEY=your-secret-key
STORAGE_BUCKET_NAME=caretaker-uploads
STORAGE_PUBLIC_URL=https://pub-<hash>.r2.dev
STORAGE_REGION=auto

CORS_ORIGIN=http://localhost:3000
